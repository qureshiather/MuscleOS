{
  "name": "muscleos",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "overrides": {
      "expo-crypto": "~14.0.0",
      "expo-application": "~6.0.2"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "dev:landing": "pnpm --filter landing dev",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
